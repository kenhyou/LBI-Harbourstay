// Harbourstay Prisma schema.
// P0 laid only the datasource + client generator. S1 introduces the first two
// tables — Listing + AvailabilityBlock — that back BC-5's CQRS read side.
//
// NOTE: this is the shared physical store. BC-2 (Availability & Inventory, the
// write side) is the CANONICAL owner of these tables; BC-5 only reads/projects
// off them. The overbooking EXCLUDE constraint on Hold (BC-2 write side) is OUT
// of scope for S1 and arrives with S3.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// BC-7 account role (guest|host|admin). `admin` is never self-registerable.
enum UserRole {
  guest
  host
  admin
}

enum ListingType {
  stay
  tour
}

enum ListingStatus {
  Published
  Unpublished
}

/// BC-2 Hold lifecycle. `active` = tentative (TTL); `committed` = permanent
/// (post-payment); `released`/`expired` = returned to supply. The overbooking
/// EXCLUDE constraint applies only to ('active','committed') rows.
enum HoldStatus {
  active
  committed
  released
  expired
}

/// BC-1 Booking lifecycle. Mirrors the shared contract `bookingStatus`.
enum BookingStatus {
  PendingPayment
  Confirmed
  Completed
  Cancelled
  Expired
  NoShow
}

/// BC-3 Payment lifecycle (S4). `Pending` on intent creation; a verified Stripe
/// webhook drives it to `Succeeded`/`Failed`. Transitions are idempotent in the
/// aggregate (re-applying a terminal state is a no-op).
enum PaymentStatus {
  Pending
  Succeeded
  Failed
}

/// BC-7 Identity & Access. The `User` aggregate's physical store. `email` is
/// unique (the registration invariant); `passwordHash` is never returned to the
/// client (the API projects the SAFE AuthUser shape at the boundary).
model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  role         UserRole @default(guest)
  createdAt    DateTime @default(now())

  @@map("user")
}

/// Canonical bookable unit (BC-2 owns writes; BC-5 projects read models off it).
model Listing {
  id          String        @id @default(uuid()) @db.Uuid
  hostId      String        @db.Uuid
  title       String
  description String
  type        ListingType   @default(stay)
  location    String
  capacity    Int
  /// Stored in minor units (integer). "From" price surfaced on the search card.
  basePrice   Int
  images      String[]      @default([])
  status      ListingStatus @default(Published)
  createdAt   DateTime      @default(now())

  availabilityBlocks AvailabilityBlock[]

  // Hits the search NFR (p95 < 500ms): search always filters status = Published
  // and often by location.
  @@index([status, location])
  @@map("listing")
}

/// Availability calendar rows. S1 uses these only to compute the *indicative*
/// availability hint (approximate — re-verified at booking time in S3). No
/// overbooking constraint here; that lives on Hold (BC-2 write side, S3).
model AvailabilityBlock {
  id        String   @id @default(uuid()) @db.Uuid
  listingId String   @db.Uuid
  checkIn   DateTime @db.Date
  checkOut  DateTime @db.Date
  /// Optional per-range price override (minor units). Unused by S1 search.
  price     Int?
  /// true = the host has blocked this range (unavailable).
  isBlocked Boolean  @default(false)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, checkIn, checkOut])
  @@map("availability_block")
}

/// BC-2 Hold aggregate — a TTL-bound exclusive claim on a listing's date range.
/// The overbooking invariant ("no two overlapping active/committed holds on a
/// listing") spans multiple Hold rows, so NO aggregate can enforce it — it is a
/// Postgres `EXCLUDE USING gist` constraint added by hand in the S3 migration
/// (Prisma can't express it). A conflicting concurrent insert fails with SQLSTATE
/// `23P01`, which the repository catches and rethrows as `OverlappingHoldException`.
model Hold {
  id        String     @id @default(uuid()) @db.Uuid
  listingId String     @db.Uuid
  checkIn   DateTime   @db.Date
  checkOut  DateTime   @db.Date
  status    HoldStatus @default(active)
  expiresAt DateTime
  createdAt DateTime   @default(now())

  @@index([listingId, status])
  @@map("hold")
}

/// BC-1 Booking aggregate — the guest's reservation commitment. References a
/// Hold (BC-2), a guest (BC-7), and a Listing (BC-2) by plain id (no FK across
/// aggregate boundaries). `priceSnapshot` is the all-in quoted total in minor
/// units, frozen at creation. `holdExpiresAt` is denormalized from the Hold so
/// the booking summary can surface the TTL without loading the Hold.
model Booking {
  id            String        @id @default(uuid()) @db.Uuid
  guestId       String        @db.Uuid
  listingId     String        @db.Uuid
  holdId        String        @db.Uuid
  checkIn       DateTime      @db.Date
  checkOut      DateTime      @db.Date
  partySize     Int
  status        BookingStatus @default(PendingPayment)
  priceSnapshot Int
  holdExpiresAt DateTime
  createdAt     DateTime      @default(now())

  @@index([guestId])
  @@map("booking")
}

/// BC-3 Payment aggregate (S4) — our purified model of an in-flight payment for a
/// booking. References the Booking by plain id (no FK across aggregates).
/// `amount` is in minor units (cents), frozen from the booking's priceSnapshot.
/// `stripePaymentIntentId` is the opaque reference from the Stripe ACL (BC-4) —
/// unique so the webhook handler can resolve the Payment from the intent.
model Payment {
  id                    String        @id @default(uuid()) @db.Uuid
  bookingId             String        @db.Uuid
  amount                Int
  currency              String        @default("USD")
  status                PaymentStatus @default(Pending)
  stripePaymentIntentId String        @unique
  createdAt             DateTime      @default(now())

  @@index([bookingId])
  @@map("payment")
}

/// BC-3 idempotency ledger (S4). One row per handled Stripe `event.id`; the PK
/// makes duplicate webhook delivery safe — if the row exists, the event was
/// already processed and the handler skips (returns 200 without re-applying).
model ProcessedWebhookEvent {
  eventId     String   @id
  processedAt DateTime @default(now())

  @@map("processed_webhook_event")
}

/// Transactional Outbox (S4, cross-cutting infra — not a BC). The event row is
/// written in the SAME transaction as the aggregate change (e.g. BookingConfirmed
/// in the confirm txn). A polling relay publishes rows where `publishedAt IS NULL`
/// and stamps `publishedAt`. At-least-once delivery → consumers must be idempotent.
model OutboxEvent {
  id          String    @id @default(uuid()) @db.Uuid
  aggregateId String    @db.Uuid
  type        String
  payload     Json
  occurredAt  DateTime  @default(now())
  publishedAt DateTime?

  @@index([publishedAt])
  @@map("outbox_event")
}

/// BC-8 Notifications delivery ledger (S4). Dedups outbox delivery on the outbox
/// event id so a duplicate (at-least-once) delivery never double-sends an email.
model NotificationLog {
  eventId String   @id @db.Uuid
  type    String
  sentAt  DateTime @default(now())

  @@map("notification_log")
}
