{
  "name": "@harbourstay/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "echo \"(api) eslint wired in S1\" && exit 0",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@harbourstay/shared": "workspace:*",
    "@nestjs-cls/transactional": "3.2.1",
    "@nestjs-cls/transactional-adapter-prisma": "1.3.5",
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.27",
    "@nestjs/cqrs": "11.0.3",
    "@nestjs/jwt": "11.0.0",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.5",
    "@prisma/client": "6.19.3",
    "bcrypt": "5.1.1",
    "stripe": "22.3.0",
    "cookie-parser": "1.4.7",
    "nestjs-cls": "6.2.1",
    "nestjs-pino": "4.6.1",
    "pino-http": "11.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@harbourstay/tsconfig": "workspace:*",
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.27",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.43",
    "@testcontainers/postgresql": "10.13.2",
    "@types/bcrypt": "5.0.2",
    "@types/cookie-parser": "1.4.8",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "26.1.0",
    "@types/supertest": "7.2.0",
    "jest": "30.4.2",
    "pino-pretty": "13.1.3",
    "prisma": "6.19.3",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "5.7.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "<rootDir>/../tsconfig.json"
        }
      ]
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
