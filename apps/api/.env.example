# Copy to .env for local dev. P0 health needs none of these (sensible defaults apply);
# they are here as the foundation for later slices.
PORT=3001
WEB_ORIGIN=http://localhost:3000
NODE_ENV=development

# Prisma + docker-compose Postgres (matches docker-compose.yml credentials):
DATABASE_URL=postgresql://harbourstay:harbourstay@localhost:5432/harbourstay?schema=public

# S4 Stripe (TEST MODE ONLY — never real keys). Both required at runtime by the
# BC-4 ACL (read via @nestjs/config in StripePaymentAdapter). Get test values from
# the Stripe dashboard; the webhook secret comes from `stripe listen` or the
# dashboard endpoint. Do NOT commit real values.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
