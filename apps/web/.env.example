# Copy to .env.local. Base URL the web app uses for server-side (RSC) fetches.
# Defaults to http://localhost:3001 if unset.
API_URL=http://localhost:3001

# Stripe publishable key (S4 Payment). PUBLIC — safe to ship to the browser;
# used client-side by Stripe.js (loadStripe) to render the Payment Element.
# Use your test-mode key (pk_test_…) from the Stripe dashboard. If unset the
# build still succeeds; the payment UI shows an "unavailable" message at runtime.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
